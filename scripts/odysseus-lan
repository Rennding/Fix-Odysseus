#!/usr/bin/env python3
"""odysseus-lan — open the web UI to your local network (e.g. a phone).

By default Odysseus binds to loopback (`127.0.0.1`), so only the machine
it runs on can reach it. This flips a couple of `.env` knobs so devices
on the SAME Wi-Fi / LAN can reach it too — and nothing else. It never
touches the public internet, and it leaves authentication on.

    odysseus-lan status        # current bind, your LAN IP, the phone URL
    odysseus-lan enable        # bind to LAN + trust your LAN origin
    odysseus-lan disable       # back to loopback-only (the safe default)

After `enable`, recreate the app so the new bind takes effect:
    docker compose down && docker compose up -d     # Docker
    # or just restart `uvicorn` / `./start-macos.sh` for a native run

Then open the printed URL on your phone and log in as usual. For a clean,
warning-free HTTPS connection over the LAN, see the "HTTPS + LAN" section
in the README (mkcert recipe).
"""
from __future__ import annotations

import os
import socket
import sys

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "_lib"))
from cli import quiet_logs, emit, fail, common_parser, run, REPO_ROOT  # noqa: E402

quiet_logs()

ENV_PATH = REPO_ROOT / ".env"
ENV_EXAMPLE = REPO_ROOT / ".env.example"

LOOPBACK = "127.0.0.1"
ALL_INTERFACES = "0.0.0.0"


def _detect_lan_ip() -> str | None:
    """Best-effort primary LAN IP. Opens a UDP socket toward a public
    address (no packets are actually sent) and reads the local end the
    OS would route through. Falls back to None when offline."""
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    try:
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
    except OSError:
        return None
    finally:
        s.close()
    if ip.startswith("127."):
        return None
    return ip


def _read_env_lines() -> list[str]:
    if ENV_PATH.exists():
        return ENV_PATH.read_text().splitlines()
    if ENV_EXAMPLE.exists():
        # Mirror the README's "cp .env.example .env" first-run step so a
        # non-technical user doesn't have to do it by hand.
        return ENV_EXAMPLE.read_text().splitlines()
    fail(f"no .env or .env.example at {REPO_ROOT}; run from the repo root.", code=2)
    return []  # unreachable; keeps type checkers happy


def _get_value(lines: list[str], key: str) -> str | None:
    """Return the value of an uncommented `KEY=...` line, or None."""
    prefix = key + "="
    for line in lines:
        stripped = line.strip()
        if stripped.startswith(prefix):
            return stripped[len(prefix):].strip()
    return None


def _upsert(lines: list[str], key: str, value: str) -> list[str]:
    """Set `KEY=value`. Replace an active line if present, else uncomment
    a commented default (`# KEY=...`), else append."""
    prefix = key + "="
    out, done = [], False
    for line in lines:
        stripped = line.strip()
        if not done and stripped.startswith(prefix):
            out.append(f"{key}={value}")
            done = True
        elif not done and stripped.startswith("#") and stripped[1:].strip().startswith(prefix):
            out.append(f"{key}={value}")
            done = True
        else:
            out.append(line)
    if not done:
        out.append(f"{key}={value}")
    return out


def _write_env(lines: list[str]) -> None:
    ENV_PATH.write_text("\n".join(lines) + "\n")


def _port(lines: list[str]) -> str:
    return _get_value(lines, "APP_PORT") or "7000"


def _phone_url(ip: str | None, port: str) -> str | None:
    return f"http://{ip}:{port}" if ip else None


def _auth_on(lines: list[str]) -> bool:
    return (_get_value(lines, "AUTH_ENABLED") or "true").lower() != "false"


def cmd_status(args):
    lines = _read_env_lines()
    bind = _get_value(lines, "APP_BIND") or LOOPBACK
    ip = _detect_lan_ip()
    port = _port(lines)
    emit({
        "env_file": str(ENV_PATH) if ENV_PATH.exists() else f"{ENV_EXAMPLE} (defaults; no .env yet)",
        "app_bind": bind,
        "lan_enabled": bind == ALL_INTERFACES,
        "auth_enabled": _auth_on(lines),
        "lan_ip": ip,
        "app_port": port,
        "phone_url": _phone_url(ip, port) if bind == ALL_INTERFACES else None,
    }, args)


def cmd_enable(args):
    lines = _read_env_lines()
    ip = _detect_lan_ip()
    port = _port(lines)

    lines = _upsert(lines, "APP_BIND", ALL_INTERFACES)
    lines = _upsert(lines, "AUTH_ENABLED", "true")  # never expose without a login wall

    if ip:
        origins = _get_value(lines, "ALLOWED_ORIGINS") or "http://localhost,http://127.0.0.1"
        lan_origin = f"http://{ip}:{port}"
        parts = [o.strip() for o in origins.split(",") if o.strip()]
        if lan_origin not in parts:
            parts.append(lan_origin)
        lines = _upsert(lines, "ALLOWED_ORIGINS", ",".join(parts))

    _write_env(lines)
    emit({
        "lan_enabled": True,
        "auth_enabled": True,
        "lan_ip": ip,
        "phone_url": _phone_url(ip, port),
        "next_step": (
            "recreate the app so the new bind takes effect: "
            "`docker compose down && docker compose up -d` (Docker), "
            "or restart uvicorn / ./start-macos.sh (native). Then open the "
            "phone_url on your device and log in."
        ),
        "warning": None if ip else (
            "could not detect a LAN IP (offline?). APP_BIND is set to 0.0.0.0; "
            "find your host's LAN address manually and open http://<that-ip>:" + port
        ),
    }, args)


def cmd_disable(args):
    if not ENV_PATH.exists():
        fail("no .env to change; bind already defaults to loopback (127.0.0.1).", code=2)
    lines = ENV_PATH.read_text().splitlines()
    lines = _upsert(lines, "APP_BIND", LOOPBACK)
    _write_env(lines)
    emit({
        "lan_enabled": False,
        "app_bind": LOOPBACK,
        "next_step": "recreate the app (docker compose down && up, or restart the native run) "
                     "to return to loopback-only.",
    }, args)


def build_parser():
    p = common_parser("odysseus-lan", "Open the Odysseus web UI to your local network.")
    sub = p.add_subparsers(dest="cmd", required=True)
    common = p._common_parents[0]
    sub.add_parser("status", parents=[common], help="show bind, LAN IP, phone URL").set_defaults(func=cmd_status)
    sub.add_parser("enable", parents=[common], help="bind to LAN + trust your LAN origin").set_defaults(func=cmd_enable)
    sub.add_parser("disable", parents=[common], help="back to loopback-only").set_defaults(func=cmd_disable)
    return p


if __name__ == "__main__":
    sys.exit(run(build_parser()))
